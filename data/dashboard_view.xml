<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="spreadsheet_dashboard_group_crm" model="spreadsheet.dashboard.group">
        <field name="name">CRM</field>
        <field name="sequence">12</field>
    </record>

    <record id="spreadsheet_dashboard_crm_pipeline" model="spreadsheet.dashboard">
        <field name="name">Pipeline Analysis</field>
        <field name="spreadsheet_binary_data" type="base64" file="spreedsheet_json_exporter/data/crm_pipeline_dashboard.json"/>
        <field name="dashboard_group_id" ref="spreadsheet_custom_crm.spreadsheet_dashboard_group_crm"/>
        <field name="group_ids" eval="[Command.link(ref('sales_team.group_sale_manager'))]"/>
        <field name="sequence">10</field>
       
    </record>

     <record id="spreadsheet_dashboard_crm_leads" model="spreadsheet.dashboard">
        <field name="name">Leads</field>
        <field name="spreadsheet_binary_data" type="base64" file="spreedsheet_json_exporter/data/crm_leads_dashboard.json"/>
        <field name="dashboard_group_id" ref="spreadsheet_custom_crm.spreadsheet_dashboard_group_crm"/>
        <field name="group_ids" eval="[Command.link(ref('sales_team.group_sale_manager'))]"/>
        <field name="sequence">20</field>
       
    </record>
</odoo>

